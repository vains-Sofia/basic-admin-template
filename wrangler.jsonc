{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "basic-admin-template",
  "compatibility_date": "2026-07-17",
  "build": {
    "command": "npm run build:cloudflare"
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  }
}
