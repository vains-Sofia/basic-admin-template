VITE_APP_TITLE=中后台管理系统
VITE_API_BASE_URL=/api
VITE_USE_MOCK=false
VITE_API_PROXY_TARGET=http://127.0.0.1:8080

VITE_OAUTH2_ENABLED=true
# OAuth2 公共客户端配置（浏览器端禁止配置 client_secret）
VITE_OAUTH2_CLIENT_ID=basic-admin-template
VITE_OAUTH2_AUTHORIZATION_URL=http://127.0.0.1:8080/oauth2/authorize
VITE_OAUTH2_TOKEN_URL=http://127.0.0.1:5173/api/oauth2/token
VITE_OAUTH2_USERINFO_URL=http://127.0.0.1:5173/api/userinfo
VITE_OAUTH2_SCOPE='openid profile'
# 留空时自动使用 {应用地址}{VITE_BASE_PATH}oauth2/callback
VITE_OAUTH2_REDIRECT_URI=http://127.0.0.1:5173/oauth2/callback
# UserInfo 中角色和权限字段路径，支持 realm_access.roles 形式的嵌套路径
VITE_OAUTH2_ROLES_CLAIM=roles
VITE_OAUTH2_PERMISSIONS_CLAIM=permissions