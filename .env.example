VITE_APP_TITLE=中后台管理系统
VITE_API_BASE_URL=/api
VITE_USE_MOCK=true
# 启用开发代理时填写，例如：http://localhost:3000
VITE_API_PROXY_TARGET=
# 项目部署后的 base path
VITE_BASE_PATH=/

# 是否启用 OAuth2 Authorization Code + PKCE 登录
VITE_OAUTH2_ENABLED=false
# OAuth2 公共客户端配置（浏览器端禁止配置 client_secret）
VITE_OAUTH2_CLIENT_ID=
VITE_OAUTH2_AUTHORIZATION_URL=
VITE_OAUTH2_TOKEN_URL=
VITE_OAUTH2_USERINFO_URL=
VITE_OAUTH2_SCOPE='openid profile'
# 留空时自动使用 {应用地址}{VITE_BASE_PATH}oauth2/callback
VITE_OAUTH2_REDIRECT_URI=
# UserInfo 中角色和权限字段路径，支持 realm_access.roles 形式的嵌套路径
VITE_OAUTH2_ROLES_CLAIM=roles
VITE_OAUTH2_PERMISSIONS_CLAIM=permissions
